# ===========================================
# StudyWise AI - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your actual values

# ─────────────────────────────────────────────────────────────────────────────
# AI PROVIDER CONFIGURATION (June 2026)
# ─────────────────────────────────────────────────────────────────────────────
# Multi-provider setup for load balancing, reliability, and cost optimization.
# The system intelligently failover between providers based on:
#   • Rate limits and quotas
#   • Content length (context window requirements)
#   • Provider priority and cost per token
#   • Real-time availability

# ── 1. GOOGLE GEMINI (AI Studio free tier) ──────────────────────────────────
#   Models: gemini-2.5-flash, gemini-2.5-flash-lite
#   Free tier: 1,500 RPD, 10/15 RPM, 1M context window
#   NOTE: gemini-2.0-flash was retired June 1, 2026 — use 2.5 only
GEMINI_API_KEY=your_gemini_api_key
VITE_GEMINI_API_KEY=your_gemini_api_key

# ── 2. GROQ (LPU inference — ultra-fast, OpenAI-compatible) ──────────────────
#   Models: llama-3.1-8b-instant, llama-3.3-70b-versatile, llama-4-scout (10M ctx)
#   Free tier: 30 RPM, no credit card required
#   Rate limits are per-organisation (shared pool, not per-key)
#   Sign up: api.groq.com
GROQ_API_KEY=your_groq_api_key
VITE_GROQ_API_KEY=your_groq_api_key

# ── 3. CEREBRAS (world's fastest inference, OpenAI-compatible) ───────────────
#   Models: llama-3.3-70b (2,300 tok/s)
#   Free tier: 1M tokens/day, 30 RPM, no credit card (default 8K context, request 128K+ in dashboard)
#   Sign up: cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key
VITE_CEREBRAS_API_KEY=your_cerebras_api_key

# ── 4. DEEPSEEK (your paid key — best value frontier model) ─────────────────
#   Models: deepseek-v4-flash (1M context, $0.14/M input tokens)
#   Paid: Requires valid credit card + API key
#   NOTE: Legacy alias "deepseek-chat" is deprecated 2026-07-24; using deepseek-v4-flash explicitly
#   Sign up: api.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key

# ── 5. OPENROUTER (28+ free models via :free suffix) ───────────────────────
#   Free models include:
#     • meta-llama/llama-4-scout (10M context — ideal for very long docs 15-20 pages)
#     • deepseek/deepseek-r1 (128K context — best free reasoning)
#     • qwen/qwen3-235b-a22b (128K context — best free coding)
#     • openai/gpt-oss-120b (131K context — strong general model)
#     • meta-llama/llama-3.3-70b-instruct (128K context — reliable fallback)
#   Free tier: 20 RPM / 200 RPD without credits; $10 one-time credit → 1,000 RPD permanently
#   NOTE: :free suffix ensures free-tier routing; roster rotates — check openrouter.ai/models
#   Sign up: openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key
VITE_OPENROUTER_API_KEY=your_openrouter_api_key

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION METADATA
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME=StudyWise AI
VITE_APP_NAME=StudyWise AI

# Used by OpenRouter to track requests and provide support
SITE_URL=http://localhost:3000
VITE_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION & DATABASE
# ─────────────────────────────────────────────────────────────────────────────

# Supabase Configuration (client-side)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Configuration (server-side)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google OAuth Configuration
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# ─────────────────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Environment mode
NODE_ENV=development

# Port
PORT=5000

# API Configuration
# For local development:     http://localhost:5000
# For production/live server: https://your-backend-domain.com
VITE_API_URL=http://localhost:5000

# ─────────────────────────────────────────────────────────────────────────────
# NOTES
# ─────────────────────────────────────────────────────────────────────────────
# 1. PROVIDER STRATEGY:
#    The AI service automatically:
#    • Tries providers in priority order (Gemini → Groq → Cerebras → DeepSeek → OpenRouter)
#    • Falls back if rate limits hit or auth fails
#    • Skips providers whose context window is too small for your document
#    • Always has Mock AI as a last resort (very low quality)
#
# 2. COST OPTIMIZATION:
#    • Start with free providers (Gemini, Groq, Cerebras, OpenRouter)
#    • Add DeepSeek ($) only if you need volume or large documents beyond free limits
#    • DeepSeek is cost-effective at $0.14/M input tokens vs other paid options
#
# 3. RATE LIMITS:
#    • All free tiers have generous per-minute limits (10-30 RPM)
#    • Groq/Cerebras limits are per-organisation (shared across all API keys for your account)
#    • System implements 60s cooldown on rate limit errors, 30s on temporary unavailability
#
# 4. CONTEXT WINDOWS:
#    • Gemini 2.5: 1M tokens (ideal for multi-page documents)
#    • Groq Llama 4 Scout: 10M tokens (handles massive docs, 15-20 pages easily)
#    • Cerebras Llama 3.3: 128K context (request expansion to 128K+ in dashboard)
#    • DeepSeek: 1M tokens
#    • OpenRouter free models: 10M to 131K depending on model
#
# 5. SETUP TIPS:
#    • Gemini & DeepSeek: Highest priority, enable first
#    • Groq: Fastest inference, highly recommended (no credit card)
#    • Cerebras: Fastest on long documents (free, sign up in < 5 min)
#    • OpenRouter: Diverse free model roster, rotate out old models
#    • Always have 2-3 providers enabled for reliability
